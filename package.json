{
  "name": "kechimochi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "web:dev": "vite --host 0.0.0.0",
    "web:start": "concurrently -k -n vite,api -c cyan,green \"npm run web:dev\" \"npm run web:server\"",
    "web:build": "tsc && vite build",
    "web:server": "cargo run --manifest-path src-tauri/Cargo.toml --bin web_server",
    "tauri": "tauri",
    "e2e:build": "tauri build --debug --no-bundle",
    "e2e:seed": "tsx e2e/fixtures/seed.ts",
    "e2e:test": "npm run e2e:build && wdio run e2e/wdio.conf.ts",
    "e2e": "npm run e2e:seed && npm run e2e:test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/ocr-service": "^2",
    "@wdio/spec-reporter": "^9",
    "@wdio/visual-service": "^6",
    "better-sqlite3": "^11",
    "concurrently": "^9.2.1",
    "edgedriver": "^6.0.1",
    "tsx": "^4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
